{
  "AllowedHosts": "*",
  "Services": {
    "Identity": "__IDENTITY_SERVICE_BASE_URL__/api/v1/identity/",
    "Institute": "__INSTITUTE_SERVICE_BASE_URL__/api/v1/institute/",
    "Billing": "__BILLING_SERVICE_BASE_URL__/api/v1/billing/"
  },
  "Jwt": {
    "Issuer": "__JWT_ISSUER__",
    "SigningKey": "__JWT_SIGNING_KEY_MINIMUM_32_CHARS__"
  },
  "ConnectionStrings": {
    "MongoAudit": "__MONGO_AUDIT_CONNECTION_STRING__",
    "Redis": "__REDIS_CONNECTION_STRING__"
  },
  "Cors": {
    "AllowedOrigins": [ "__FRONTEND_ORIGIN__" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
