{
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "__JWT_ISSUER__",
    "SigningKey": "__JWT_SIGNING_KEY_MINIMUM_32_CHARS__",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "ConnectionStrings": {
    "SqlServer": "__SQL_SERVER_CONNECTION_STRING__",
    "MongoAudit": "__MONGO_AUDIT_CONNECTION_STRING__",
    "Redis": "__REDIS_CONNECTION_STRING__"
  },
  "RabbitMQ": {
    "Host": "__RABBITMQ_HOST__",
    "Port": 5672,
    "UserName": "__RABBITMQ_USERNAME__",
    "Password": "__RABBITMQ_PASSWORD__",
    "VirtualHost": "__RABBITMQ_VIRTUAL_HOST__",
    "Exchange": "__RABBITMQ_EXCHANGE__"
  },
  "Cors": {
    "AllowedOrigins": [ "__FRONTEND_ORIGIN__" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
